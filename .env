# Uncomment the hosted backend API URL if you want direct calls (will require CORS):
# VITE_API_URL=https://nxsocial.nxsys.in/api
# Hosted callback base (optional):
# VITE_CALLBACK_BASE_URL=https://nxsocial.nxsys.in

# Use the Vite dev server proxy to route `/api` to the hosted backend (avoids CORS in dev)
VITE_API_URL=https://nxsocial.nxsys.in/api
VITE_PROXY_TARGET=https://nxsocial.nxsys.in
# VITE_PROXY_TARGET=http://192.168.0.114:8000/
# The callback URL must point to your frontend so the browser is redirected
# back to the app after the provider completes OAuth. In dev this should
# be the dev server origin. Change to your deployed frontend URL as needed.
# VITE_CALLBACK_BASE_URL=http://localhost:8080